PORT=8080
GO_ENV=development

# Same PostgreSQL instance as the gateway, without Prisma-specific params
DATABASE_URL=postgres://root:root@localhost:5432/ivorioci?sslmode=disable

# Must match JWT_ACCESS_SECRET in the gateway (.env)
JWT_ACCESS_SECRET=access_secret_very_long_string_here

# Storage paths (created automatically on first run)
VIDEO_STORAGE_PATH=./storage/videos
THUMBNAIL_STORAGE_PATH=./storage/thumbnails

# Public base URL of the gateway — used to build thumbnail URLs returned in the API
# e.g. thumbnailUrl = http://localhost:3000/api/thumbnails/<uuid>.jpg
PUBLIC_BASE_URL=http://localhost:3000/api
